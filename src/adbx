#!/bin/zsh

# adbx - unified ADB helper
# Usage: adbx <command> [args]
#
# Tab completion is provided by _adbx in the same directory (~/.local/bin/_adbx).
# For it to work, ~/.local/bin must be on your fpath (add to .zshrc if needed):
#   fpath=(~/.local/bin $fpath)

ADBX_DIR="${0:A:h}"
ADBX_SCRIPT="${0:A}"

for _f in "$ADBX_DIR/adbx-commands/"*.sh; do
  source "$_f"
done
unset _f

# ── help & dispatch ────────────────────────────────────────────────────────────

cmd_help() {
  echo "adbx - unified ADB helper"
  echo ""
  echo "Usage: adbx <command> [args]"
  echo ""
  echo "Commands:"
  echo "  animate on|off                  Enable or disable animations"
  echo "  theme light|dark|auto           Set theme"
  echo "  install <file.apk>              Install an APK"
  echo "  record                          Record screen to Desktop (Enter to stop)"
  echo "  screenshot                      Take screenshot to Desktop"
  echo "  talkback on|off                 Enable or disable TalkBack"
  echo "  password-manager on|off         Enable or disable password/credential managers (emulator only)"
  echo "  auto-reverse <subcmd>           Manage ADB reverse daemon"
  echo "    subcmds: listener|install|start|stop|restart|status|uninstall|logs|test|help"
  echo "  help                            Show this help"
}

case "$1" in
  animate)      shift; cmd_animate "$@" ;;
  theme)        shift; cmd_theme "$@" ;;
  install)      shift; cmd_install "$@" ;;
  record)       cmd_record ;;
  screenshot)   cmd_screenshot ;;
  talkback)     shift; cmd_talkback "$@" ;;
  password-manager) shift; cmd_password_manager "$@" ;;
  auto-reverse) shift; cmd_auto_reverse "$@" ;;
  help|--help|-h) cmd_help ;;
  "")
    cmd_help
    ;;
  *)
    echo "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
